{
  "name": "edinburgh-gardens-zombie-fps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "multiplayer": "node server/multiplayer-server.mjs",
    "game:cli": "node scripts/game-cli.mjs",
    "game:repl": "node scripts/game-cli.mjs --headed repl",
    "electron": "npm run build && electron .",
    "build": "tsc --noEmit && vite build",
    "package": "npm run build && npm run package:web && npm run package:desktop:nobuild",
    "package:web": "node scripts/package-web.mjs",
    "package:desktop": "npm run build && npm run package:desktop:nobuild",
    "package:desktop:nobuild": "electron-builder",
    "test": "vitest",
    "test:run": "vitest run --reporter=dot",
    "research:check": "node scripts/validate-research-assets.mjs",
    "research:ledger": "node scripts/generate-2026-object-audit-ledger.mjs",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 5481 --strictPort",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:quick": "node scripts/run-e2e.mjs --skip-build",
    "perf:bench": "vitest bench tests/performance.bench.ts --run --reporter=verbose",
    "perf:report": "node scripts/performance-report.mjs",
    "perf:check": "node scripts/performance-report.mjs --include-tests"
  },
  "dependencies": {
    "three": "^0.185.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.callumalpass.edinburghgardens2030",
    "productName": "Edinburgh Gardens 2030",
    "directories": {
      "output": "release/desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Game"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
