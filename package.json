{
  "name": "edinburgh-gardens-zombie-fps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "multiplayer": "node server/multiplayer-server.mjs",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "research:check": "node scripts/validate-research-assets.mjs",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 5481 --strictPort",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:quick": "node scripts/run-e2e.mjs --skip-build",
    "perf:bench": "vitest bench --run"
  },
  "dependencies": {
    "three": "^0.185.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
